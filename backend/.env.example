NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://scale_admin:scale_admin_password@localhost:5432/scale_admin
FRONTEND_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=scale_admin_session
SESSION_IDLE_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_DAYS=14

# Local development seed defaults. Override these before seeding shared/non-local databases.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_FULL_NAME=Local Admin
# Set to true only when you intentionally want the seed to rotate the existing admin password.
SEED_ADMIN_RESET_PASSWORD=false
